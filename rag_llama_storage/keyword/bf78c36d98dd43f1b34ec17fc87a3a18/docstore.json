u7b26\u5408(12\u5206)**\uff1a\u6b65\u9a5f\u5177\u9ad4\u660e\u78ba\uff0c\u6578\u91cf\u9069\u4e2d(3-15\u6b65)\uff0c\u908f\u8f2f\u6e05\u6670\n**\u90e8\u5206(7\u5206)**\uff1a\u6b65\u9a5f\u904e\u7c97(\u6bcf\u6b65\u5305\u542b\u591a\u500b\u7368\u7acb\u52d5\u4f5c)\u6216\u904e\u7d30(\u904e\u591a\u6b65\u9a5f)\n**\u4e0d\u7b26(3\u5206)**\uff1a\u6b65\u9a5f\u904e\u65bc\u7c21\u5316\u6216\u7f3a\u5931\u95dc\u9375\u6b65\u9a5f\n**\u793a\u4f8b**\uff1a\n- \u7b26\u5408\uff1a\u6bd4\u5982\u5e73\u53f0\u4e0a\u52d5\u706b\u4f5c\u696d\uff0c\u4f5c\u696d\u6b65\u9a5f\u5206\u70ba:1.\u4eba\u54e1\u651c\u5e36\u5de5\u6a5f\u5177(\u96fb\u710a\u6a5f\u3001\u710a\u69cd\u3001\u9762\u7f69)\u4e0a\u722c\u68af\u81f3\u4f5c\u696d\u73fe\u5834\u30012.\u63a5\u5165\u81e8\u6642\u96fb\u76e4\u4e26\u65bd\u4f5c\u96fb\u7e9c\u4fdd\u8b77\u84cb\u677f\u30013.\u6e05\u7406\u52d5\u706b\u4f5c\u696d\u5468\u908a\u53ef\u71c3\u7269\u4e26\u92ea\u8a2d\u4e0b\u65b9\u9632\u706b\u6bef\u30014.\u9032\u884c\u5e73\u53f0\u710a\u63a5\u4f5c\u696d\u30015.\u5730\u8173\u677f\u5b89\u88dd\u30016.\u6574\u7406\u73fe\u5834\u3002\n- \u90e8\u5206\uff1a\u6b65\u9a5f\u904e\u7c97(\u6bcf\u6b65\u5305\u542b\u591a\u500b\u7368\u7acb\u52d5\u4f5c)\u6216\u904e\u7d30(\u904e\u591a\u6b65\u9a5f)\n- \u4e0d\u7b26\uff1a\u6bd4\u5982\u5e73\u53f0\u4e0a\u52d5\u706b\u4f5c\u696d\uff0c\u4f5c\u696d\u6b65\u9a5f\u5206\u70ba:1.\u5de5\u6a5f\u5177\u5165\u5834\u30012.\u5e73\u53f0\u7684\u8b77\u6b04\u710a\u63a5\u53ca\u5730\u8173\u677f\u5b89\u88dd\u30013.\u6574\u7406\u73fe\u5834\u3002\u4f5c\u696d\u6b65\u9a5f\u4e0d\u5177\u9ad4\uff0c\u5982:\u5de5\u6a5f\u5177\u5982\u4f55\u904b\u9001\u9032\u5165\u73fe\u5834\u3001\u4f7f\u7528\u710a\u63a5\u7684\u5de5\u6cd5\u672a\u8aaa\u660e\uff1b\u7f3a\u5c11\u95dc\u9375\u6b65\u9a5f\uff0c\u5982:\u710a\u63a5\u8a2d\u5099\u7f3a\u5c11\u63a5\u5165\u81e8\u6642\u96fb\u76e4\u7684\u6b65\u9a5f\u8aaa\u660e", "mimetype": "text/plain", "start_char_idx": 2, "end_char_idx": 403, "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "b8d20406-dabd-4992-94cf-189421043053": {"__data__": {"id_": "b8d20406-dabd-4992-94cf-189421043053", "embedding": null, "metadata": {"header_path": "/"}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "88a16205-f5c6-4c26-a4ca-7b7d85d62f98", "node_type": "4", "metadata": {}, "hash": "0c39c1217d45a15847af323868516a9dce9be2e7426eb1cc5ecabcd9c5bbaeac", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "\u4e8c\u3001\u5206\u6790\u8cea\u91cf\u5be9\u6838\u6a19\u6e96(60\u5206) 2.2 \u5371\u5bb3\u8b58\u5225\u5168\u9762(12\u5206)\n**\u7b26\u5408(12\u5206)**\uff1a\u5f9e\u4eba\u3001\u6a5f\u3001\u6599\u3001\u6cd5\u3001\u74b0\u4e94\u7dad\u5ea6\u5168\u9762\u8b58\u5225\n**\u90e8\u5206(7\u5206)**\uff1a\u8b58\u5225\u4e86\u4e3b\u8981\u5371\u5bb3\uff0c\u4f46\u7f3a\u5c11\u67d0\u4e9b\u7dad\u5ea6\n**\u4e0d\u7b26(3\u5206)**\uff1a\u50c5\u8b58\u5225\u8868\u9762\u5371\u5bb3\uff0c\u660e\u986f\u907a\u6f0f\n**\u793a\u4f8b**\uff1a\n- \u4e0d\u7b26\uff1a\u300c\u4eba\u6a5f\u6599\u6cd5\u74b0\uff0c\u53ea\u8003\u616e\u4e00\u500b\u7dad\u5ea6\u7684\u5371\u5bb3\u300d\n- \u90e8\u5206\uff1a\u300c\u4eba\u6a5f\u6599\u6cd5\u74b0\uff0c\u8003\u616e2~4\u500b\u7dad\u5ea6\u7684\u5371\u5bb3\u300d\n- \u7b26\u5408\uff1a\n\u300c\u4eba-\u4f55\u4eba\u53c3\u8207\u5177\u9ad4\u54ea\u4e00\u6b65\u9a5f\u4f5c\u696d\u3001\u4eba\u54e1\u7684\u8cc7\u8cea\u662f\u5426\u7b26\u5408(\u5982\u7279\u79cd\u4f5c\u4e1a\u64cd\u4f5c\u8bc1\u3001\u7279\u79cd\u8bbe\u5907\u4f5c\u4e1a\u4eba\u5458\u8bc1)\u3001\u4eba\u54e1\u9632\u8b77\u5668\u5177/\u8a2d\u5099\u662f\u5426\u8db3\u5920\uff1b\n\u6a5f-\u8a72\u6b65\u9a5f\u4f7f\u7528\u4e86\u90a3\u4e9b\u5de5\u6a5f\u5177\uff0c\u5404\u81ea\u53ef\u80fd\u884d\u751f\u90a3\u4e9b\u5371\u5bb3\u3002\u50c5\u5728\u63d0\u5230\"\u8173\u624b\u67b6\u3001\u9ad8\u7a7a\u4f5c\u696d\u3001\u6389\u843d\u7269\u3001\u6f5b\u5728\u6389\u4e0b\u7269\u4f53\u3001\u8d77\u91cd\u4f5c\u696d\u3001\u540a\u88dd\u4f5c\u696d\u3001\u53ef\u651c\u5f0f\u96fb\u52d5\u8a2d\u5099\u3001\u5de5\u6a5f\u5177\u3001\u79fb\u52d5/\u65cb\u8f49\u8a2d\u5099\u3001\u5de5\u5177\u3001\u5207\u5272\u3001\u52d5\u706b\u3001\u710a\u63a5\u3002\n\u6599-\u8a72\u6b65\u9a5f\u4e2d\u4f7f\u7528\u4f55\u7a2e\u6750\u6599\u3001\u7269\u6599\u3001\u5316\u5b78\u54c1\uff0c\u5404\u81ea\u53ef\u80fd\u884d\u751f\u90a3\u4e9b\u5371\u5bb3\u3002\n\u6cd5-\u4f5c\u696d\u65b9\u6cd5\u53ca\u9069\u7576\u7684\u4f5c\u696d\u6b65\u9a5f\uff1b\n\u74b0-\u4f5c\u696d\u74b0\u5883\u689d\u4ef6\uff0c\u5982\u4f5c\u696d\u5834\u5730\u4e0d\u5e73\u6574\u3001\u5730\u9762\u6709\u6cb9\u6c59\u3001\u5b58\u5728\u53ef\u71c3\u6bc5\u7136\u6216\u7c89\u5875\u3002\u53c8\u5982\u4f5c\u696d\u5340\u57df\u9130\u8fd1\u52d5\u706b\u3001\u9130\u8fd1\u7ba1\u9053\u6253\u958b\u4f5c\u696d\u3001\u53d7\u9650\u7a7a\u9593\u4f5c\u696d\u3001\u9ad8\u8655\u4f5c\u696d\uff0c\u53ef\u80fd\u884d\u751f\u4ea4\u53c9\u4f5c\u696d\u98a8\u96aa\u3002\u300d\n\u9700\u8b80\u53d6`references/risk_library.md`,\u6307\u51fa\u5c0d\u61c9\u7684\u6f5b\u5728\u5371\u5bb3\u662f\u5426\u8207JSA\u5206\u6790\u4e2d\u7684\u5371\u5bb3\u76f8\u7b26\u5408\u3002", "mimetype": "text/plain", "start_char_idx": 2, "end_char_idx": 516, "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "f06a8e9a-6764-4274-ae49-8c8a3a644e9b": {"__data__": {"id_": "f06a8e9a-6764-4274-ae49-8c8a3a644e9b", "embedding": null, "metadata": {"header_path": "/"}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "67ca671b-feaa-4280-b000-55d4b0188c69", "node_type": "4", "metadata": {}, "hash": "5245f46530fce96369dbdce60a0e0378ba85f94f251392e9000f72778df72047", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "\u4e8c\u3001\u5206\u6790\u8cea\u91cf\u5be9\u6838\u6a19\u6e96(60\u5206) 2.3 \u5371\u5bb3\u63cf\u8ff0\u5177\u9ad4(12\u5206)\n**\u7b26\u5408(12\u5206)**\uff1a\u5177\u9ad4\u63cf\u8ff0\u300c\u4ec0\u9ebc\u60c5\u6cc1\u4e0b\u6703\u5