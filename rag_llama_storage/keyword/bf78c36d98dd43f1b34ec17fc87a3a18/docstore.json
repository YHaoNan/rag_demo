a-82e9335fbae0": {"node_ids": ["e6d87600-3e3e-43cf-821b-095bd647162d"], "metadata": {"header_path": "/"}}, "08f250cb-5dfc-4874-a06c-1d1d0544eddd": {"node_ids": ["9fdba6ee-4091-42ce-93d1-3c13bb492197"], "metadata": {"header_path": "/"}}}, "docstore/data": {"1399cbf0-0ec9-4fee-a679-3a05a83f2d54": {"__data__": {"id_": "1399cbf0-0ec9-4fee-a679-3a05a83f2d54", "embedding": null, "metadata": {"header_path": "/"}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "1b4a2a2f-0806-410d-ad83-338a1991889e", "node_type": "4", "metadata": {}, "hash": "91cd4f67ee188b37b62950fd72b3f8d19daaa1bc25698bce84b0da686fd2f1ef", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "\u6982\u8ff0\nJSA\u5408\u89c4\u6027\u6821\u9a8c\u9700\u8981\u7ecf\u5386\u4ee5\u4e0b\u56db\u4e2a\u6b65\u9aa4\uff1a\n1. \u683c\u5f0f\u5408\u89c4\u6027\u68c0\u67e5\n2. \u5206\u6790\u8d28\u91cf\u8bc4\u4f30\n3. \u5c4f\u969c\u5145\u5206\u7a0b\u5ea6\u8bc4\u4f30\n4. \u98ce\u9669\u51c6\u786e\u7a0b\u5ea6\u8bc4\u4f30\n\u6bcf\u4e00\u4e2a\u6b65\u9aa4\u7684\u7ec6\u5219\u5982\u4e0b\uff1a\n**\u6b65\u9a5f1: \u683c\u5f0f\u5408\u898f\u6027\u6aa2\u67e5**\n| \u7de8\u865f | \u68c0\u67e5\u9879 | \u8a55\u5206\u8981\u9ede |\n|----|--------|----------|\n| 1.1 | \u62a5\u544a\u6807\u9898\u660e\u786e | \u6807\u9898\u5305\u542b\u4f5c\u4e1a\u540d\u79f0\u3001\u5730\u70b9\u3001\u65e5\u671f\u4e09\u8981\u7d20 |\n| 1.2 | \u4f5c\u4e1a\u6b65\u9aa4\u7f16\u53f7\u8fde\u7eed | \u7f16\u53f7\u8fde\u7eed\u65e0\u8df3\u53f7\u3001\u65e0\u91cd\u590d |\n| 1.3 | \u5371\u5bb3\u4e0e\u63aa\u65bd\u5bf9\u5e94  | \u6bcf\u4e2a\u5371\u5bb3\u90fd\u6709\u5bf9\u5e94\u7684\u63a7\u5236\u63aa\u65bd |\n| 1.4 | \u7b7e\u6838\u680f\u4f4d\u5b8c\u6574 | \u5305\u542b\u5206\u6790\u4eba\u54e1\u3001\u5ba1\u6838\u3001\u6279\u51c6\u4e09\u7ea7\u7b7e\u540d\u53ca\u65e5\u671f |\n| 1.5 | \u7d27\u6025\u5e94\u53d8\u5b8c\u6574 | \u5305\u542b\u62a5\u8b66\u65b9\u5f0f\u3001\u758f\u6563\u8def\u7ebf\u3001\u6025\u6551\u8054\u7d61\u3001\u5e94\u6025\u8bbe\u5907\u4f4d\u7f6e |\n**\u6b65\u9a5f2: \u5206\u6790\u8cea\u91cf\u8a55\u4f30**\n| \u7de8\u865f | \u68c0\u67e5\u9879  | \u8a55\u5206\u8981\u9ede |\n|----|--------|----------|\n| 2.1 | \u4f5c\u4e1a\u6b65\u9aa4\u5206\u89e3\u9002\u5f53 | \u6b65\u9aa4\u5177\u4f53\u660e\u786e\uff08\u5efa\u8bae 3-15 \u6b65\uff09\uff0c\u903b\u8f91\u6e05\u6670 |\n| 2.2 | \u5371\u5bb3\u8bc6\u522b\u5168\u9762 | \u4ece\u4eba\u3001\u673a\u3001\u6599\u3001\u6cd5\u3001\u73af\u4e94\u7ef4\u5ea6\u5168\u9762\u8bc6\u522b |\n| 2.3 | \u5371\u5bb3\u63cf\u8ff0\u5177\u4f53 | \u5177\u4f53\u63cf\u8ff0\"\u4ec0\u4e48\u60c5\u51b5\u4e0b\u4f1a\u5bfc\u81f4\u4ec0\u4e48\u4f24\u5bb3\" |\n| 2.4 | \u63a7\u5236\u63aa\u65bd\u9075\u5faa\u5c42\u7ea7\u539f\u5219 | \u6d88\u9664\u2192\u66ff\u4ee3\u2192\u5de5\u7a0b\u2192\u7ba1\u7406\u2192PPE\uff0c\u4f18\u5148\u9ad8\u5c42\u7ea7 |\n| 2.5 | \u63a7\u5236\u63aa\u65bd\u5177\u4f53\u53ef\u64cd\u4f5c | \u660e\u786e\"\u8c01\u3001\u4f55\u65f6\u3001\u505a\u4ec0\u4e48\"\uff0c\u53ef\u6267\u884c\u53ef\u9a8c\u8bc1 |\n**\u6b65\u9a5f3: \u5c4f\u969c\u5145\u5206\u7a0b\u5ea6\u8a55\u4f30**\n| \u7de8\u865f | \u68c0\u67e5\u9879 | \u8a55\u5206\u8981\u9ede |\n|----|--------|----------|\n| 3.1 | \u8b58\u5225\u5de5\u7a0b\u6216\u7ba1\u7406\u63aa\u65bd(\u9632\u6b62\u4e8b\u4ef6\u767c\u751f) | \u8bc6\u522b 3 \u9879\u4ee5\u4e0a\u6709\u6548\u7684\u5de5\u7a0b\u6216\u7ba1\u7406\u63aa\u65bd\uff08\u9632\u6b62\u4e8b\u4ef6\u53d1\u751f\uff09\uff0c\u5982\u80fd\u91cf\u9694\u79bb\u3001\u901a\u98ce\u3001\u57f9\u8bad\u7b49 |\n| 3.2 | \u8b58\u5225\u500b\u4eba\u9632\u8b77\u63aa\u65bd(\u4fdd\u8b77\u500b\u4eba) | \u8bc6\u522b 2 \u9879\u4ee5\u4e0a\u6709\u6548\u7684\u500b\u4eba\u9632\u8b77\u63aa\u65bd\uff08\u4fdd\u62a4\u4eba\u5458\uff09\uff0c\u5982 PPE\u3001\u8f93\u6c14\u7ba1\u9762\u7f69\u3001\u6709\u673a\u6ee4\u6bd2\u7f50\u9632\u6bd2\u53e3\u7f69\u3001\u4e2a\u4eba\u9632\u62a4\u8863\u7b49 |\n| 3.3 | \u8b58\u5225\u4e8b\u5f8c\u61c9\u6025\u63aa\u65bd(\u6e1b\u8f15\u5f8c\u679c) | \u8bc6\u522b 2 \u9879\u4ee5\u4e0a\u6709\u6548\u7684\u4e8b\u5f8c\u61c9\u6025\u63aa\u65bd\uff08\u51cf\u8f7b\u540e\u679c\uff09\uff0c\u5982\u5e94\u6025\u54cd\u5e94\u8a08\u5283\u3001\u5e94\u6025\u6551\u52a9\u5668\u6750\u7b49 |\n**\u6b65\u9a5f4: \u98ce\u9669\u51c6\u786e\u7a0b\u5ea6\u8a55\u4f30**\n| \u7de8\u865f | \u68c0\u67e5\u9879 | \u8a55\u5206\u8981\u9ede |\n|----|--------|----------|\n| 4.1 | \u4f5c\u4e1a\u7c7b\u578b\u5206\u7c7b\u5339\u914d | JSA \u4e2d\u7684\u4f5c\u4e1a\u7c7b\u578b\u4e0e\u98ce\u9669\u5e93\u5206\u7c7b\u5339\u914d\u7a0b\u5ea6 |\n| 4.2 | \u6bd4\u5c0d\u5371\u5bb3\u56e0\u7d20\u5b8c\u6574\u6027 | \u6db5\u76d6\u98ce\u9669\u5e93\u4e2d\u8be5\u7c7b\u578b 80% \u4ee5\u4e0a\u7684\u4e3b\u8981\u5371\u5bb3\u56e0\u7d20 |\n| 4.3 | \u9a57\u8b49\u63a7\u5236\u63aa\u65bd\u7b26\u5408\u63a8\u85a6\u505a\u6cd5 | \u63a7\u5236\u63aa\u65bd\u4e0e\u98ce\u9669\u5e93\u63a8\u8350\u505a\u6cd5\u4e00\u81f4\u6216\u66f4\u4f18 |\n| 4.4 | \u8b58\u5225\u907a\u6f0f\u98a8\u96aa | \u4e3b\u52a8\u8bc6\u522b\u5e76\u8865\u5145\u4e86\u98ce\u9669\u5e93\u4e2d\u672a\u6db5\u76d6\u7684\u7279\u5b9a\u98ce\u9669 |", "mimetype": "text/plain", "start_char_idx": 2, "end_char_idx": 1120, "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "52daaaee-2b8e-4da8-8845-4cd67ed30709": {"__data__": {"id_": "52daaaee-2b8e-4da8-8845-4cd67ed30709", "embedding": null, "metadata": {"header_path": "/"}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "fa2393c3-0049-4c33-9659-c743cb9eed0c", "node_type": "4", "metadata": {}, "hash": "1114e9be072aea0f898791e7f23afd7fcf582e442777208fb769736462aa723e", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "\u4e00\u3001\u683c\u5f0f\u5408\u898f\u6027\u5be9\u6838\u6a19\u6e96(15\u5206) 1.1 \u5831\u544a\u6a19\u984c\u660e\u78ba(3\u5206)\n**\u7b26\u5408(3\u5206)**\uff1a\u6a19\u984c\u5305\u542b\u4f5c\u696d\u540d\u7a31\u3001\u5730\u9