_path": "/"}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "32c01671-1e84-4b2a-9387-665a0200aa38", "node_type": "4", "metadata": {}, "hash": "5c6b92ce62f34e9173c66be27bf9b6c16a75ab85da8b519a997c46353d5e2f52", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "\u4e09\u3001\u5c4f\u969c\u5145\u5206\u7a0b\u5ea6\u5be9\u6838\u6a19\u6e96(10\u5206) 3.2 \u500b\u4eba\u9632\u8b77\u63aa\u65bd\u8b58\u5225\u5b8c\u6574(3\u5206)\n**\u7b26\u5408(3\u5206)**\uff1a\u8b58\u52252\u9805\u4ee5\u4e0a\u6709\u6548\u7684\u500b\u4eba\u9632\u8b77\u63aa\u65bd\n**\u90e8\u5206(2\u5206)**\uff1a\u8b58\u52251\u9805\n**\u4e0d\u7b26(1\u5206)**\uff1a\u672a\u8b58\u5225\n**\u500b\u4eba\u9632\u8b77\u63aa\u65bd\u793a\u4f8b**\uff1a\n- \u500b\u4eba\u9632\u8b77\u88dd\u5099(PPE)\n- \u5b89\u5168\u5e36/\u9632\u589c\u5668\n- \u8f93\u6c14\u7ba1\u9762\u7f69\n- \u6709\u673a\u6ee4\u6bd2\u7f50\u9632\u6bd2\u53e3\u7f69\n- \u4e2a\u4eba\u9632\u62a4\u8863", "mimetype": "text/plain", "start_char_idx": 2, "end_char_idx": 162, "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "a8b5229c-75d2-48d7-8dde-35c3b083886d": {"__data__": {"id_": "a8b5229c-75d2-48d7-8dde-35c3b083886d", "embedding": null, "metadata": {"header_path": "/"}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "ff63b80d-51d3-4a00-888e-9095b90331f2", "node_type": "4", "metadata": {}, "hash": "5e707c0ef827b4238227ad53d6b687feb096b7fa209bfb70ecc9f8331d20f444", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "\u4e09\u3001\u5c4f\u969c\u5145\u5206\u7a0b\u5ea6\u5be9\u6838\u6a19\u6e96(10\u5206) 3.3 \u4e8b\u5f8c\u61c9\u6025\u63aa\u65bd\u8b58\u5225\u5b8c\u6574(3\u5206)\n**\u7b26\u5408(3\u5206)**\uff1a\u8b58\u52252\u9805\u4ee5\u4e0a\u6709\u6548\u7684\u4e8b\u5f8c\u61c9\u6025\u63aa\u65bd\n**\u90e8\u5206(2\u5206)**\uff1a\u8b58\u52251\u9805\n**\u4e0d\u7b26(1\u5206)**\uff1a\u672a\u8b58\u5225\n**\u4e8b\u5f8c\u61c9\u6025\u63aa\u65bd\u793a\u4f8b**\uff1a\n- \u5e94\u6025\u54cd\u5e94\u8a08\u5283(\u542b\u758f\u6563\u8def\u7dda\u3001\u73fe\u5834\u98a8\u5411\u6a19)\n- \u5e94\u6025\u6551\u52a9\u5668\u6750\n- \u624b\u63d0\u5f0f\u6d88\u9632\u6ec5\u706b\u5668\n- \u6025\u6551\u7bb1\n- \u6c27\u6c14\u6025\u6551\u5668", "mimetype": "text/plain", "start_char_idx": 2, "end_char_idx": 166, "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "a803340a-8492-4856-ae02-a63813511db5": {"__data__": {"id_": "a803340a-8492-4856-ae02-a63813511db5", "embedding": null, "metadata": {"header_path": "/"}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "3423bda5-7405-46ab-a3a3-0a5b147f5679", "node_type": "4", "metadata": {}, "hash": "67ad734dc30e20b419208f9ee6afad31a6f7a29db5d874e7ccf58df3ab1c5677", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "\u56db\u3001\u98ce\u9669\u51c6\u786e\u7a0b\u5ea6\u5be9\u6838\u6a19\u6e96(15\u5206) 4.1 \u4f5c\u696d\u985e\u578b\u8207\u98a8\u96aa\u5eab\u5206\u985e\u5339\u914d(3\u5206)\n**\u7b26\u5408(3\u5206)**\uff1aJSA\u4e2d\u7684\u4f5c\u696d\u6b65\u9a5f\u63cf\u8ff0\u8207\u98a8\u96aa\u5eab\u4e2d\u7684\u4f5c\u696d\u985e\u578b\u5b9a\u7fa9\u63cf\u8ff0\u4e00\u81f4\n**\u90e8\u5206(2\u5206)**\uff1a\u57fa\u672c\u5339\u914d\u4f46\u63cf\u8ff0\u6709\u5dee\u7570\n**\u4e0d\u7b26(1\u5206)**\uff1a\u4e0d\u5339\u914d\u6216\u90e8\u5206\u7121\u6cd5\u5c0d\u61c9\n**\u793a\u4f8b**\uff1a\n\u7b26\u5408:\n- \u6b65\u9a5f\u63cf\u8ff0\u4e2d\uff0c\u6d89\u53ca\"\u5b9a\u904b\"\u3001\"\u540a\u88dd\"\u3001\"\u8d77\u91cd\"\u3001\"\u8d77\u540a\"\uff0c\u548c\u98a8\u96aa\u5eab\u4e2d\u7684\u540a\u88dd\u4f5c\u696d\u5b9a\u7fa9\"\u4f7f\u7528\u8d77\u91cd\u8a2d\u5099\u540a\u904b\u91cd\u7269\u7684\u4f5c\u696d\"\uff0c\u9ad8\u5ea6\u91cd\u5408\uff0c\u5224\u5b9a\u7b26\u5408\u3002\n- \u6b65\u9a5f\u63cf\u8ff0\u4e2d\uff0c\u6d89\u53ca\"\u914d\u63a5\u4e34\u65f6\u7ba1\u7ebf\u53ca\u673a\u6cf5\"\u3001\"\u914d\u63a5\u81e8\u6642\u96fb\u76e4\"\u3001\"\u63a5\u5165\u4e34\u65f6\u7528\u7535\"\uff0c\u548c\u98a8\u96aa\u5eab\u4e2d\u7684\u81e8\u6642\u7528\u96fb\u4f5c\u696d\u5b9a\u7fa9\"\u975e\u6c38\u4e45\u6027\u96fb\u6c23\u88dd\u7f6e\u7684\u5b89\u88dd\u3001\u4f7f\u7528\u4f5c\u696d\"\uff0c\u9ad8\u5ea6\u91cd\u5408\uff0c\u5224\u5b9a\u7b26\u5408\u3002\n- \u6b65\u9a5f\u63cf\u8ff0\u4e2d\uff0c\u6d89\u53ca\"\u63d2\u76f2\u677f\"\u3001\"\u5207\u65b7\u96fb\u6e90\"\u3001\"\u95dc\u9589\u524d\u5f8c\u95a5\"\u3001\"\u95dc\u9589\u5207\u65b7\u95a5\"\u3001\"\u6392\u7a7a\"\u3001\"\u6392\u6db2\"\uff0c\u548c\u98a8\u96aa\u5eab\u4e2d\u7684\u80fd\u91cf\u9694\u96e2\u4f5c\u696d\u5b9a\u7fa9\"\u5207\u65b7\u3001\u9694\u96e2\u5316\u5b78\u54c1\u6216\u80fd\u91cf\u6e90\u7684\u4f5c\u696d\"\uff0c\u9ad8\u5ea6\u91cd\u5408\uff0c\u5224\u5b9a\u7b26\u5408\u3002\n\u6b65\u9a5f\u63cf\u8ff0\u4e2d\uff0c\u6d89\u53ca\"\u5207\u5272\"\u3001\"\u4f7f\u7528\u96fb\u52d5\u5de5\u5177\"\u3001\"\u710a\u63a5\"\u3001\"\u7814\u78e8\"\u3001\"\u6253\u62cb\"\u3001\"\u6253\u64ca\"\uff0c\u548c\u98a8\u96aa\u5eab\u4e2d\u7684\u52d5\u706b\u4f5c\u696d\u5b9a\u7fa9\"\u80fd\u7522\u751f\u706b\u7130\u3001\u706b\u82b1\u6216\u71b1\u8868\u9762\u7684\u4f5c\u696d\uff0c\u5305\u62ec\u710a\u63a5\u3001\u5207\u5272\u3001\u6253\u78e8\u7b49\"\uff0c\u9ad8\u5ea6\u91cd\u5408\uff0c\u5224\u5b9a\u7b26\u5408\u3002", "mimetype": "text/plain", "start_char_idx": 2, "end_char_idx": 475, "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "e6d87600-3e3e-43cf-821b-095bd647162d": {"__data__": {"id_": "e6d87600-3e3e-43cf-821b-095bd647162d", "embedding": null, "metadata": {"header_path": "/"}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "c9f6d3a9-2162-41c5-903a-82e9335fbae0", "node_type": "4", "metadata": {}, "hash": "d7d85ce51a017603c009a31a6d11010f69f8a5a3a9a27502ba2a7440c5c2ad96", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "\u56db\u3001\u98ce\u9669\u51c6\u786e\u7a0b\u5ea6\u5be9\u6838\u6a19\u6e96(15\u5206) 4.2 \u6bd4\u5c0d\u5371\u5bb3\u56e0\u7d20\u5b8c\u6574\u6027(4\u5206) 4.3 \u9a57\u8b49\u63a7\u5236\u63aa\u65bd\u7b26\u5408\u63a8\u85a6\u505a\u6cd5(4\u5206)\n**\u7b26\u5408(4\u5206)**\uff1a\u6db5\u84cb\u4e86\u98a8\u96aa\u5eab\u4e2d\u8a72\u4f5c\u696d\u985e\u578b80%\u4ee5\u4e0a\u7684\u5371\u5bb3\u56e0\u7d20\n**\u90e8\u5206(3\u5206)**\uff1a\u6db5\u84cb50-80%\n**\u4e0d\u7b26(2\u5206)**\uff1a\u6db5\u84cb\u4e0d\u8db350%\n\u5224\u5b9a\u6d41\u7a0b:\n(1)\u89e3\u6790JSA\u5206\u6790\u4e2d\u7684\u5de5\u4f5c\u540d\u7a31\u6216\u4f5c\u696d\u540d\u7a31\u4ee5\u53ca\u4f5c\u696d\u5de5\u4f5c\u5834\u6240\u6216\u4f4d\u7f6e\uff0c\u5224\u65b7\u4f5c\u696d\u5834\u6240\n(2)\u6bd4\u5c0d\"\u4f5c\u696d\u5834\u6240\u5224\u5b9a.md\"\u6a94\u4e2d\u7684\u76f8\u61c9\u53ef\u80fd\u5371\u5bb3\u56e0\u7d20\u3001\u4e0d\u53ef\u80fd\u5371\u5bb3\u56e0\u7d20\n(3)\u89e3\u6790JSA\u5206\u6790\u4e2d\u7684\u4f5c\u696d\u6b65\u9a5f\u63cf\u8ff0\u53ef\u80fd\u5c0d\u5e94\u7684\u7279\u6b8a\u4f5c\u696d\u985e\u578b\n(4)\u6bd4\u5c0dJSA\u5206\u6790\u4e2d\u7684\u6bcf\u4e00\u6b65\u9a5f\u4e2d\u7684\u5c0d\u61c9\u5371\u5bb3\u56e0\u7d20\u548c\"\u98a8\u96aa\u5eab.md\"\u4e2d\u5c0d\u61c9\u7684\u7279\u6b8a\u4f5c\u696d\u7684\u4e3b\u8981\u5371\u5bb3\u56e0\u7d20\n**\u4e0d\u5e94\u6709\u4f46\u88ab\u5217\u51fa\u7684\u5371\u5bb3**\uff1a\n- \u6839\u636e\u7684\u4f5c\u4e1a\u5834\u6240\u3001\u5730\u70b9\u6216\u662f\u7279\u6b8a\u4f5c\u696d\u985e\u578b\u660e\u786e\u6392\u9664\u8be5\u5371\u5bb3\n- \u4f46JSA\u5206\u6790\u62a5\u544a\u4e2d\u4ecd\u5217\u51fa\u4e86\u8be5\u5371\u5bb3\n**\u793a\u4f8b**\uff1a\u5316\u9a8c\u5ba4\u4f5c\u4e1a\u5217\u51fa\"\u9ad8\u5904\u5760\u843d\"\u548c\"\u540a\u88c5\u4f5c\u4e1a\"\n**\u5efa\u8bae\u8868\u8ff0**\uff1a\n> \u8be5\u5371\u5bb3\u4e0e\u4f5c\u4e1a\u5167\u5bb9\u4e0a\u4e0b\u6587\u4e0d\u7b26\uff0c[\u4f5c\u4e1a\u5834\u6240\u3001\u5730\u70b9\u3001\u7279\u6b8a\u4f5c\u696d\u985e\u578b]\u4e0d\u5177\u5907\u8be5\u5371\u5bb3\u7684\u53d1\u751f\u6761\u4ef6\uff0c\u5efa\u8bae\u5ba1\u5be6\u662f\u5426\u5220\u9664\u3002\n**\u5e94\u8be5\u6709\u4f46\u7f3a\u5931\u7684\u5371\u5bb3**\uff1a\n- \u6839\u636e\u7684\u4f5c\u4e1a\u5834\u6240\u3001\u5730\u70b9\u6216\u662f\u7279\u6b8a\u4f5c\u696d\u985e\u578b\uff0c\u5e94\u5b58\u5728\u8be5\u5371\u5bb3\n- \u4f46JSA\u5206\u6790\u62a5\u544a\u4e2d\u672a\u5217\u51fa\u8be5\u5371\u5bb3\n**\u793a\u4f8b**\uff1a\u540a\u88c5\u4f5c\u4e1a\u672a\u5217\u51fa\"\u8d77\u91cd\u4f24\u5bb3\"\n**\u5efa\u8bae\u8868\u8ff0**\uff1a\n> \u6839\u636e\u4f5c\u4e1a\u5834\u6240\u3001\u5730\u70b9\u3001\u7279\u6b8a\u4f5c\u4e1a\u7c7b\u578b\uff0c\u5e94\u8bc6\u522b\u51fa[\u5371\u5bb3\u7c7b\u578b]\uff0c\u5efa\u8bae\u8865\u5145\u3002\n**\u7b26\u5408(4\u5206)**\uff1a\u63a7\u5236\u63aa\u65bd\u8207\u98a8\u96aa\u5eab\u63a8\u85a6\u505a\u6cd5\u4e00\u81f4\u6216\u66f4\u512a\n**\u90e8\u5206(3\u5206)**\uff1a\u90e8\u5206\u4e00\u81f4\n**\u4e0d\u7b26(2\u5206)**\uff1a\u660e\u986f\u4e0d\u7b26\u6216\u7f3a\u5931\u95dc\u9375\u63aa\u65bd\n\u5224\u5b9a\u6d41\u7a0b:\n(1)\u89e3\u6790JSA\u5206\u6790\u4e2d\u7684\u4f5c\u696d\u6b65\u9a5f\u63cf\u8ff0\u53ef\u80fd\u5c0d\u5e94\u7684\u7279\u6b8a\u4f5c\u696d\u985e\u578b\n(2)\u6bd4\u5c0dJSA\u5206\u6790\u4e2d\u7684\u6bcf\u4e00\u6b65\u9a5f\u4e2d\u7684\u5c0d\u61c9\u5371\u5bb3\u7684\u63a7\u5236\u63aa\u65bd(\u9632\u8b77\u63aa\u65bd)\u548c\"\u98a8\u96aa\u5eab.md\"\u4e2d\u5c0d\u61c9\u7684\u7279\u6b8a\u4f5c\u696d\u7684\u63a7\u5236\u63aa\u65bd", "mimetype": "text/plain", "start_char_idx": 2, "end_char_idx": 735, "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "9fdba6ee-4091-42ce-93d1-3c13bb492197": {"__data__": {"id_": "9fdba6ee-4091-42ce-93d1-3c13bb492197", "embedding": null, "metadata": {"header_path": "/"}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "08f