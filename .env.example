OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_API_KEY=
OPENAI_CHAT_BASE_URL=https://api.openai.com/v1

# Embedding
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Shared chat model for contextualization/router/regex/answer fallback
OPENAI_CHAT_MODEL=gpt-4.1-mini

# Contextualization
OPENAI_CONTEXT_MODEL=
OPENAI_CONTEXT_MAX_CHARS=4000
OPENAI_CONTEXT_TIMEOUT_SECONDS=60
OPENAI_CONTEXT_MAX_RETRIES=2
OPENAI_CONTEXT_MAX_WORKERS=4
OPENAI_CONTEXT_TASK_QUEUE_SIZE=16

# Router
OPENAI_ROUTER_MODEL=
OPENAI_ROUTER_TIMEOUT_SECONDS=60
OPENAI_ROUTER_MAX_RETRIES=2

# Regex generation
OPENAI_REGEX_MODEL=
OPENAI_REGEX_TIMEOUT_SECONDS=30
OPENAI_REGEX_MAX_RETRIES=1

# Answer generation
OPENAI_ANSWER_MODEL=
OPENAI_ANSWER_TIMEOUT_SECONDS=60
OPENAI_ANSWER_MAX_RETRIES=2

# Web task queue
OPENAI_WEB_TASK_QUEUE_SIZE=64
